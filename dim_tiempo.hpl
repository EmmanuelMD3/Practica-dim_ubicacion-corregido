  <transform>
    <name>completar dim_tiempo</name>
    <type>ScriptValueMod</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>// Año, mes y día vienen del Calculator
var anio_tiempo = anyo_id;
var mes_tiempo = mes_id;
var dia_numero = diam_id;

// Trimestre
var trimestre_tiempo;

if (mes_tiempo >= 1 &amp;&amp; mes_tiempo &lt;= 3) {
    trimestre_tiempo = 1;
} else if (mes_tiempo >= 4 &amp;&amp; mes_tiempo &lt;= 6) {
    trimestre_tiempo = 2;
} else if (mes_tiempo >= 7 &amp;&amp; mes_tiempo &lt;= 9) {
    trimestre_tiempo = 3;
} else {
    trimestre_tiempo = 4;
}

// Nombre del mes
var mes_descripcion_tiempo = "";

if (mes_tiempo == 1) {
    mes_descripcion_tiempo = "Enero";
} else if (mes_tiempo == 2) {
    mes_descripcion_tiempo = "Febrero";
} else if (mes_tiempo == 3) {
    mes_descripcion_tiempo = "Marzo";
} else if (mes_tiempo == 4) {
    mes_descripcion_tiempo = "Abril";
} else if (mes_tiempo == 5) {
    mes_descripcion_tiempo = "Mayo";
} else if (mes_tiempo == 6) {
    mes_descripcion_tiempo = "Junio";
} else if (mes_tiempo == 7) {
    mes_descripcion_tiempo = "Julio";
} else if (mes_tiempo == 8) {
    mes_descripcion_tiempo = "Agosto";
} else if (mes_tiempo == 9) {
    mes_descripcion_tiempo = "Septiembre";
} else if (mes_tiempo == 10) {
    mes_descripcion_tiempo = "Octubre";
} else if (mes_tiempo == 11) {
    mes_descripcion_tiempo = "Noviembre";
} else if (mes_tiempo == 12) {
    mes_descripcion_tiempo = "Diciembre";
}

// Día como texto
var dia_tiempo = String(dia_numero);

// Año fiscal, mes fiscal y día fiscal
// En este caso lo dejamos igual al calendario normal
var anio_fiscal_tiempo = anio_tiempo;
var mes_fiscal_tiempo = mes_tiempo;
var dia_fiscal_tiempo = dia_numero;

// Fechas de gran evento según el caso conectaX
var descripcion_gran_evento = "Sin evento";

if (mes_tiempo == 1 &amp;&amp; dia_numero == 1) {
    descripcion_gran_evento = "Año Nuevo";
} else if (mes_tiempo == 1 &amp;&amp; dia_numero == 6) {
    descripcion_gran_evento = "Día de Reyes";
} else if (mes_tiempo == 2 &amp;&amp; dia_numero == 14) {
    descripcion_gran_evento = "Día del Amor y la Amistad";
} else if (mes_tiempo == 4 &amp;&amp; dia_numero == 30) {
    descripcion_gran_evento = "Día del Niño";
} else if (mes_tiempo == 5 &amp;&amp; dia_numero == 10) {
    descripcion_gran_evento = "Día de las Madres";
} else if (mes_tiempo == 9 &amp;&amp; dia_numero == 15) {
    descripcion_gran_evento = "Grito de Independencia";
} else if (mes_tiempo == 10 &amp;&amp; dia_numero == 31) {
    descripcion_gran_evento = "Halloween";
} else if (mes_tiempo == 11 &amp;&amp; dia_numero == 1) {
    descripcion_gran_evento = "Día de Todos los Santos";
} else if (mes_tiempo == 11 &amp;&amp; dia_numero == 2) {
    descripcion_gran_evento = "Día de Muertos";
} else if (mes_tiempo == 12 &amp;&amp; dia_numero == 12) {
    descripcion_gran_evento = "Día de la Virgen de Guadalupe";
} else if (mes_tiempo == 12 &amp;&amp; dia_numero == 24) {
    descripcion_gran_evento = "Nochebuena";
} else if (mes_tiempo == 12 &amp;&amp; dia_numero == 25) {
    descripcion_gran_evento = "Navidad";
} else if (mes_tiempo == 12 &amp;&amp; dia_numero == 31) {
    descripcion_gran_evento = "Fin de Año";
}

// Fecha tiempo
var fecha_tiempo = fecha;
</jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
      <field>
        <name>anio_tiempo</name>
