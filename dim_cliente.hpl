        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>// Limpiar segmento_cliente
var segmento_limpio = segmento_cliente;

if (segmento_limpio != null &amp;&amp; segmento_limpio != "") {
    segmento_limpio = segmento_limpio.replace(/-/g, " ");
    segmento_limpio = segmento_limpio.toLowerCase();
    segmento_limpio = segmento_limpio.charAt(0).toUpperCase() + segmento_limpio.slice(1);
}

// Limpiar regimen_fiscal
var regimen_fiscal_limpio = regimen_fiscal;

if (regimen_fiscal_limpio != null &amp;&amp; regimen_fiscal_limpio != "") {
    regimen_fiscal_limpio = regimen_fiscal_limpio.replace(/_/g, " ");
    regimen_fiscal_limpio = regimen_fiscal_limpio.replace(/-/g, " ");
    regimen_fiscal_limpio = regimen_fiscal_limpio.toLowerCase();
    regimen_fiscal_limpio = regimen_fiscal_limpio.charAt(0).toUpperCase() + regimen_fiscal_limpio.slice(1);
}
</jsScript_script>
      </jsScript>
