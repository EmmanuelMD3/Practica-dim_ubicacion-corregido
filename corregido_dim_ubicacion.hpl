  <transform>
    <name>Formula</name>
    <type>Formula</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <formulas>
      <formula>
        <field_name>region_ubicacion</field_name>
        <formula>PROPER(LOWER(LEFT([region_raw],FIND("-",[region_raw])-1)))</formula>
        <set_na>N</set_na>
        <value_length>-1</value_length>
        <value_precision>-1</value_precision>
        <value_type>2</value_type>
      </formula>
      <formula>
        <field_name>estado_ubicacion</field_name>
        <formula>SUBSTITUTE([estado_raw],"*","")</formula>
        <set_na>N</set_na>
        <value_length>-1</value_length>
        <value_precision>-1</value_precision>
        <value_type>2</value_type>
      </formula>
      <formula>
        <field_name>ciudad_ubicacion</field_name>
        <formula>[ciudad_raw]</formula>
        <set_na>N</set_na>
        <value_length>-1</value_length>
        <value_precision>-1</value_precision>
        <value_type>2</value_type>
      </formula>
      <formula>
        <field_name>calle_ubicacion</field_name>
